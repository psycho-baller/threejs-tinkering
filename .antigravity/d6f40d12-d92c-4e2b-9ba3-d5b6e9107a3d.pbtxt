        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Main Render Loop logic using Framerate-Independent clock delta"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  useFrame((state) => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (!initialized.current) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const time = state.clock.getElapsedTime();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Clamp delta time to maximum of 0.05s to prevent massive coordinates teleportation when page lags"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const dt = Math.min(state.clock.getDelta(), 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Track mouse projection onto focal depth plane"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const { pointer, camera } = state;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const tempV = new THREE.Vector3(pointer.x, pointer.y, 0.5);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    tempV.unproject(camera);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const dir = tempV.sub(camera.position).normalize();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Project mouse cursor onto depth coordinate z=-1.5 (center depth of crowd)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const targetZ = -1.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let distance = (targetZ - camera.position.z) / dir.z;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (Math.abs(dir.z) < 0.001) distance = 4.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const projectedMousePos = camera.position.clone().add(dir.multiplyScalar(distance));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // A. Run GPGPU Simulation Step"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const backupTarget = gl.getRenderTarget();"
