          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rWrist = createJoint(0.2, 0.35, -0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    case 7: // Walking / Striding Motion"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Alternating stride"
