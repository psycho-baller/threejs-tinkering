          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Push all bones of the skeleton"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"torso\", start: torsoStart, end: torsoEnd, radius: 0.15, weight: 0.28 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"head\", start: headStart, end: headEnd, radius: 0.11, weight: 0.18 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"neck\", start: neckStart, end: neckEnd, radius: 0.05, weight: 0.02 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"l_upperarm\", start: lShoulder, end: lElbow, radius: 0.045, weight: 0.06 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"l_lowerarm\", start: lElbow, end: lWrist, radius: 0.035, weight: 0.06 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"r_upperarm\", start: rShoulder, end: rElbow, radius: 0.045, weight: 0.06 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"r_lowerarm\", start: rElbow, end: rWrist, radius: 0.035, weight: 0.06 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"l_thigh\", start: lThighS, end: lThighE, radius: 0.065, weight: 0.07 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"l_shin\", start: lShinS, end: lShinE, radius: 0.05, weight: 0.07 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"r_thigh\", start: rThighS, end: rThighE, radius: 0.065, weight: 0.07 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bones.push({ id: \"r_shin\", start: rShinS, end: rShinE, radius: 0.05, weight: 0.07 });"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return bones;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Samples a single 3D point on or inside a capsule segment"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function sampleBonePoint(bone: Bone, out: { x: number; y: number; z: number }) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const { start, end, radius } = bone;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const dx = end.x - start.x;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const dy = end.y - start.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const dz = end.z - start.z;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const lengthSq = dx * dx + dy * dy + dz * dz;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (lengthSq < 0.0001) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // It\'s a sphere (like the head)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const u1 = Math.random();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const u2 = Math.random();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const theta = u1 * Math.PI * 2.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const phi = Math.acos(2.0 * u2 - 1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Uniform volumetric sphere packing"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const r = radius * (0.8 + 0.2 * Math.pow(Math.random(), 0.3));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    out.x = start.x + r * Math.sin(phi) * Math.cos(theta);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    out.y = start.y + r * Math.sin(phi) * Math.sin(theta);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    out.z = start.z + r * Math.cos(phi);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Parametric point along segment length"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // We prefer points packed a bit around the center for volume, but fairly uniform"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const t = Math.random();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const px = start.x + t * dx;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const py = start.y + t * dy;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const pz = start.z + t * dz;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Make a unit vector perpendicular to the segment (dx, dy, dz)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rx = Math.random() - 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let ry = Math.random() - 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rz = Math.random() - 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Cross product of (dx,dy,dz) and random (rx,ry,rz)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let pxVal = dy * rz - dz * ry;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let pyVal = dz * rx - dx * rz;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let pzVal = dx * ry - dy * rx;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lengthP = Math.sqrt(pxVal * pxVal + pyVal * pyVal + pzVal * pzVal);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (lengthP < 0.0001) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rx += 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pxVal = dy * rz - dz * ry;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pyVal = dz * rx - dx * rz;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pzVal = dx * ry - dy * rx;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    lengthP = Math.sqrt(pxVal * pxVal + pyVal * pyVal + pzVal * pzVal);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Normalize perpendicular axis P"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  pxVal /= lengthP;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  pyVal /= lengthP;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  pzVal /= lengthP;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Compute second perpendicular Axis Q via cross product of Segment D and axis P"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const segmentLen = Math.sqrt(lengthSq);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const ndx = dx / segmentLen;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const ndy = dy / segmentLen;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const ndz = dz / segmentLen;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let qxVal = ndy * pzVal - ndz * pyVal;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let qyVal = ndz * pxVal - ndx * pzVal;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let qzVal = ndx * pyVal - ndy * pxVal;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const lengthQ = Math.sqrt(qxVal * qxVal + qyVal * qyVal + qzVal * qzVal);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  qxVal /= lengthQ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  qyVal /= lengthQ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  qzVal /= lengthQ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Generate random radial angle and radial radius"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const angle = Math.random() * Math.PI * 2.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Dynamic thickness - slightly thinner in limbs, volumetric"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Radial scaling: (0.7 + 0.3 * rand) gives a nice solid shell and glowing inner vapor"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const rScale = radius * (0.65 + 0.35 * Math.sqrt(Math.random()));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const cosAngle = Math.cos(angle);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const sinAngle = Math.sin(angle);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  out.x = px + (pxVal * cosAngle + qxVal * sinAngle) * rScale;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  out.y = py + (pyVal * cosAngle + qyVal * sinAngle) * rScale;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  out.z = pz + (pzVal * cosAngle + qzVal * sinAngle) * rScale;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Sets up layout and parameters of the 15 figures in our crowd simulation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "interface FigureLayout {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  poseType: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  offsetX: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  offsetY: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  offsetZ: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  rotationY: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  scale: number;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  isStandout: boolean;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export const CROWD_LAYOUTS: FigureLayout[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 0. The Standout Figure (Centered, larger, facing camera!)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 0, offsetX: 0, offsetY: -1.0, offsetZ: 0.0, rotationY: 0.0, scale: 1.18, isStandout: true },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 1. Inner Circle Background Left"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 1, offsetX: -1.8, offsetY: -1.0, offsetZ: -1.5, rotationY: 0.35, scale: 1.1, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 2. Inner Circle Background Right"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 2, offsetX: 1.8, offsetY: -1.0, offsetZ: -1.5, rotationY: -0.35, scale: 1.1, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 3. Middle Left Ground"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 3, offsetX: -3.5, offsetY: -1.0, offsetZ: -2.0, rotationY: 0.55, scale: 1.08, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 4. Middle Right Ground"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 4, offsetX: 3.5, offsetY: -1.0, offsetZ: -2.0, rotationY: -0.55, scale: 1.08, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 5. Deep Center Left"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 5, offsetX: -1.0, offsetY: -1.0, offsetZ: -3.4, rotationY: 0.15, scale: 1.05, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 6. Deep Center Right"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 6, offsetX: 1.0, offsetY: -1.0, offsetZ: -3.4, rotationY: -0.15, scale: 1.05, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 7. Middle Far Left"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 7, offsetX: -5.0, offsetY: -1.0, offsetZ: -3.0, rotationY: 0.70, scale: 1.0, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 8. Middle Far Right"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 0, offsetX: 5.0, offsetY: -1.0, offsetZ: -3.0, rotationY: -0.70, scale: 1.0, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 9. Deep Far Left"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 1, offsetX: -2.8, offsetY: -1.0, offsetZ: -4.8, rotationY: 0.30, scale: 0.98, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 10. Deep Far Right"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 2, offsetX: 2.8, offsetY: -1.0, offsetZ: -4.8, rotationY: -0.30, scale: 0.98, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 11. Core Back Projection"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 3, offsetX: 0.0, offsetY: -1.0, offsetZ: -5.5, rotationY: 0.0, scale: 0.95, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 12. Distant Deep Left"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 4, offsetX: -4.5, offsetY: -1.0, offsetZ: -5.2, rotationY: 0.50, scale: 0.95, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 13. Distant Deep Right"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 5, offsetX: 4.5, offsetY: -1.0, offsetZ: -5.2, rotationY: -0.50, scale: 0.95, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 14. Outer Wing Background Left"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  { poseType: 6, offsetX: -6.4, offsetY: -1.0, offsetZ: -4.5, rotationY: 0.85, scale: 0.9, isStandout: false },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "/**"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Generates initial and target coordinate datasets for the massive 524,288 GPGPU particle grid."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * We pack positions into the 512 x 1024 Float32Array texture structure."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Target contains the beautiful Amber human crowds."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " * Initial contains a dispersed dark-gold starry vacuum so particles visually fly matching the \"breath of life\" to form the bodies."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: " */"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "export function generateCrowdTextures(width: number, height: number): {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  targetPositions: Float32Array;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  initialPositions: Float32Array;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "} {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const size = width * height; // 512 * 1024 = 524,288 particles"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const targetPositions = new Float32Array(size * 4);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const initialPositions = new Float32Array(size * 4);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // We have 15 figures mapped in groups of rows"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Figure 0: 128 rows (65,536 particles) - The Standout Figure"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Figure 1 to 14: 64 rows each (32,768 particles each)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // TotalRows = 128 + 14 * 64 = 1024 rows."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // ColWidth = 512."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const tempPt = { x: 0, y: 0, z: 0 };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  for (let figIdx = 0; figIdx < CROWD_LAYOUTS.length; figIdx++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const layout = CROWD_LAYOUTS[figIdx];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const bonesList = getPoseBones(layout.poseType);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Compute cumulative sum of weights for choosing bone"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const cumulativeWeights: number[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    let currentSum = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (const bone of bonesList) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      currentSum += bone.weight;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      cumulativeWeights.push(currentSum);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Determine particle count and start index in pixel array"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const startRow = figIdx === 0 ? 0 : 128 + (figIdx - 1) * 64;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const numRows = figIdx === 0 ? 128 : 64;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const particleStart = startRow * width;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const count = numRows * width;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Generate coordinates"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    for (let i = 0; i < count; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const idx = particleStart + i;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Select segment based on bone weight"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const randValue = Math.random();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      let chosenBone = bonesList[bonesList.length - 1];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      for (let b = 0; b < bonesList.length; b++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        if (randValue <= cumulativeWeights[b]) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          chosenBone = bonesList[b];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "          break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "        }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Sample raw point inside body structure"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      sampleBonePoint(chosenBone, tempPt);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Apply scale, rotation around Y (yaw angles), and spatial position offset"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const angle = layout.rotationY;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const cosA = Math.cos(angle);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const sinA = Math.sin(angle);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Local Rotations"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const rx = tempPt.x * cosA - tempPt.z * sinA;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const rz = tempPt.x * sinA + tempPt.z * cosA;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Apply height & placement shifts"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const worldX = rx * layout.scale + layout.offsetX;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const worldY = tempPt.y * layout.scale + layout.offsetY;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const worldZ = rz * layout.scale + layout.offsetZ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Pack into target Float32Array (RGBA texture channel configuration)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // We pass the layout rotation or speed seed in Alpha"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      targetPositions[idx * 4 + 0] = worldX;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      targetPositions[idx * 4 + 1] = worldY;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      targetPositions[idx * 4 + 2] = worldZ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Store standout flag in Alpha"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      targetPositions[idx * 4 + 3] = layout.isStandout ? 1.0 : 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Initial coordinates: We pack the initial positions scattered around in a wide sphere"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // with a soft vortex shape to allow beautiful initial explosion-to-silhouette morph"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const initRadius = 4.0 + Math.random() * 8.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const initAngle = Math.random() * Math.PI * 2.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const initHeight = (Math.random() - 0.5) * 6.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      initialPositions[idx * 4 + 0] = Math.cos(initAngle) * initRadius;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      initialPositions[idx * 4 + 1] = initHeight;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      initialPositions[idx * 4 + 2] = Math.sin(initAngle) * initRadius;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Also tag standout"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      initialPositions[idx * 4 + 3] = layout.isStandout ? 1.0 : 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return { targetPositions, initialPositions };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
      }
    }
    overwrite: true
  }
}
