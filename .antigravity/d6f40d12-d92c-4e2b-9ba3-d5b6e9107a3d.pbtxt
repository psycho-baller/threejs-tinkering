          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Generates 8 standard poses as bone lists"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function getPoseBones(poseType: number): Bone[] {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const bones: Bone[] = [];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Define bone indices"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const torsoStart = createJoint(0, 0.4, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const torsoEnd = createJoint(0, 1.15, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const neckStart = createJoint(0, 1.15, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const neckEnd = createJoint(0, 1.25, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Sphere centered at (0, 1.38, 0)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const headStart = createJoint(0, 1.38, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const headEnd = createJoint(0, 1.38, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Default Leg Joints"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lThighS = createJoint(-0.11, 0.4, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lThighE = createJoint(-0.13, 0.0, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lShinS = createJoint(-0.13, 0.0, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lShinE = createJoint(-0.13, -0.45, 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rThighS = createJoint(0.11, 0.4, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rThighE = createJoint(0.13, 0.0, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rShinS = createJoint(0.13, 0.0, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rShinE = createJoint(0.13, -0.45, 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Default Arm Joints"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lShoulder = createJoint(-0.18, 1.1, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lElbow = createJoint(-0.28, 0.75, -0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let lWrist = createJoint(-0.24, 0.40, 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rShoulder = createJoint(0.18, 1.1, 0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rElbow = createJoint(0.28, 0.75, -0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  let rWrist = createJoint(0.24, 0.40, 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Customize poses depending on poseType"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  switch (poseType) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    case 0: // Idle Standing"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Hand resting slightly down-forward"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lElbow = createJoint(-0.25, 0.7, -0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lWrist = createJoint(-0.2, 0.35, 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rElbow = createJoint(0.25, 0.7, -0.05);"
