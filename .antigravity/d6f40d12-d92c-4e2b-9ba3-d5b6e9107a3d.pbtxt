        }
        lines {
          text: "      lShinS = createJoint(-0.15, 0.02, 0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lShinE = createJoint(-0.12, -0.42, 0.3); // left foot forward"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rThighE = createJoint(0.12, 0.02, -0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rShinS = createJoint(0.12, 0.02, -0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rShinE = createJoint(0.14, -0.42, -0.3); // right foot backward"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Arm swing opposite legs"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
