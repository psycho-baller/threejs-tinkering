        }
        lines {
          text: "      lShinE = createJoint(-0.28, -0.45, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rThighE = createJoint(0.2, 0.0, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rShinS = createJoint(0.2, 0.0, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rShinE = createJoint(0.28, -0.45, 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      break;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    case 6: // Looking Up / Hopeful Reach"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Left arm reaching high up-forward"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lElbow = createJoint(-0.22, 1.4, 0.1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lWrist = createJoint(-0.18, 1.85, 0.25);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Right arm down and back"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
