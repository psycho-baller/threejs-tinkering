          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rWrist = createJoint(0.42, 1.75, 0.2);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Left arm slightly bent at side"
