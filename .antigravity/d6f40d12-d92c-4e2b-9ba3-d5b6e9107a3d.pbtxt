        lines {
          text: "            <div className=\"space-y-4 leading-relaxed font-sans text-zinc-300\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <section className=\"space-y-1\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <h3 className=\"font-semibold text-zinc-100 font-mono text-xs text-amber-400\">Total Particles: 524,288</h3>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  No meshes are handled on the CPU. Coordinates are loaded into double-buffered 512 x 1024 32-bit floating-point textures. All transformation loops run entirely on the GPU."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </section>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <section className=\"space-y-1\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <h3 className=\"font-semibold text-zinc-100 font-mono text-xs text-amber-400\">The \"Standout Figure\" Segment</h3>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  The first 65,536 coordinates represent the central standout figure. High-precision shader branching multiplies their luminance by 2.2x and drives them in a faster, higher-frequency curl noise to create an active focal point."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </section>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <section className=\"space-y-1\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <h3 className=\"font-semibold text-zinc-100 font-mono text-xs text-amber-400\">Ashima Curl Noise Vector Field</h3>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  Calculates true analytical curl derivatives from 3D Simplex GPGPU noise. This creates the highly aesthetic organic wind velocity turbulence with zero CPU lag."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              </section>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "              <section className=\"space-y-1\">"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <h3 className=\"font-semibold text-zinc-100 font-mono text-xs text-amber-400\">Bloom Post-Processing</h3>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                <p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                  We utilize multi-pass mip-mapped Gaussian blur and high-pass additive color buffers. This builds glowing halos without hard edges around concentrated particle clusters."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                </p>"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
