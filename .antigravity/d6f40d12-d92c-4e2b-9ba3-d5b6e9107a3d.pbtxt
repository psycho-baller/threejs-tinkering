          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lWrist = createJoint(-0.15, 0.45, -0.2); // left arm back"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rElbow = createJoint(0.24, 0.75, 0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      rWrist = createJoint(0.18, 0.48, 0.25); // right arm forward"
