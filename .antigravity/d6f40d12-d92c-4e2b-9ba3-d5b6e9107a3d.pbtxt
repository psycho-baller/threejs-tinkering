        }
        lines {
          text: "  vec3 p_x0 = snoiseVec3( p - dx );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  vec3 p_x1 = snoiseVec3( p + dx );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  vec3 p_y0 = snoiseVec3( p - dy );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  vec3 p_y1 = snoiseVec3( p + dy );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  vec3 p_z0 = snoiseVec3( p - dz );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  vec3 p_z1 = snoiseVec3( p + dz );"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  float x = p_y1.z - p_y0.z - p_z1.y + p_z0.y;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  float y = p_z1.x - p_z0.x - p_x1.z + p_x0.z;"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  float z = p_x1.y - p_x0.y - p_y1.x + p_y0.x;"
