          text: "  vec4 s1 = floor(b1)*2.0 + 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec4 sh = -step(h, vec4(0.0));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww ;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p0 = vec3(a0.xy,h.x);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p1 = vec3(a0.zw,h.y);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p2 = vec3(a1.xy,h.z);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p3 = vec3(a1.zw,h.w);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Normalise gradients"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2, p2), dot(p3,p3)));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  p0 *= norm.x;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  p1 *= norm.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  p2 *= norm.z;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  p3 *= norm.w;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Mix final noise value"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  m = m * m;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return 42.0 * dot( m*m, vec4( dot(p0,x0), dot(p1,x1),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "                                dot(p2,x2), dot(p3,x3) ) );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "vec3 snoiseVec3( vec3 x ){"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float s  = snoise(vec3( x ));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float s1 = snoise(vec3( x.y - 19.1, x.z + 33.4, x.x + 5.2 ));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float s2 = snoise(vec3( x.z + 74.2, x.x - 124.5, x.y + 99.4 ));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 c = vec3( s, s1, s2 );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return c;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Curl noise computes the rotation/curl of a 3D simplex field to create dynamic fluid swirls"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "vec3 curlNoise( vec3 p ){"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const float e = .1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 dx = vec3( e, 0.0, 0.0 );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 dy = vec3( 0.0, e, 0.0 );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 dz = vec3( 0.0, 0.0, e );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p_x0 = snoiseVec3( p - dx );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p_x1 = snoiseVec3( p + dx );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p_y0 = snoiseVec3( p - dy );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p_y1 = snoiseVec3( p + dy );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p_z0 = snoiseVec3( p - dz );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 p_z1 = snoiseVec3( p + dz );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float x = p_y1.z - p_y0.z - p_z1.y + p_z0.y;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float y = p_z1.x - p_z0.x - p_x1.z + p_x0.z;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float z = p_x1.y - p_x0.y - p_y1.x + p_y0.x;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const float divisor = 1.0 / ( 2.0 * e );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return normalize( vec3( x, y, z ) * divisor );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "void main() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec4 currentData = texture2D(uCurrentPosition, vUv);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 pos = currentData.xyz;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // High-precision standout checking based on row ratios (v-coordinate)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Our standout figure is Figure 0, which sits in rows 0 to 127 out of 1024, i.e., vUv.y < 0.125"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bool standout = vUv.y < uStandoutRatio;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Retrieve base static shape target position in 3D"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 crowdTarget = texture2D(uTargetPosition, vUv).xyz;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Generate an alternate Cosmic Vortex motion target"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float angle = atan(pos.z, pos.x);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float radius = length(pos.xz);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Dynamic vortex spiral calculations"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float waveOffset = sin(pos.y * 1.5 - uTime * 0.4) * 0.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Vortex target radius depends slightly on particles to create thickness"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float vortexTargetRadius = 1.6 + 0.9 * sin(pos.y * 0.8 + uTime * 0.3) + fract(vUv.x * 23.4) * 0.7;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Add angular velocity"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float vortexTargetAngle = angle + uDeltaTime * (standout ? 2.5 : 1.25) + pos.y * 0.35;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Slowly carry particles upward"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float vortexTargetY = pos.y + uDeltaTime * (standout ? 1.4 : 0.7);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Respawn looping inside the cylinder vortex when exiting boundary"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (vortexTargetY > 4.5) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    vortexTargetY = -1.5 + fract(vUv.y * 455.4) * 1.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // slightly randomize radius on loop"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    vortexTargetRadius = 1.0 + fract(vUv.x * 883.3) * 1.5;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 vortexTarget = vec3("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    cos(vortexTargetAngle) * vortexTargetRadius,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    vortexTargetY,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    sin(vortexTargetAngle) * vortexTargetRadius"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  );"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Blend target based on chaos (0.0: strict figures, 1.0: cosmic vortex cascade)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 finalTarget = mix(crowdTarget, vortexTarget, uChaos);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Force vectors compilation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 force = vec3(0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Force A: Target Snapping"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Standout figures snap harder and faster to keep clean visual definition"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 toTarget = finalTarget - pos;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float snapStrength = standout ? uReturnSpeed * 1.8 : uReturnSpeed;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  force += toTarget * snapStrength;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Force B: Ambient / Turbulent GPU Curl Noise "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Standout figure displays higher frequency energy and speed"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float noiseFreq = standout ? uNoiseFrequency * 1.7 : uNoiseFrequency;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float noiseStr = standout ? uNoiseStrength * 1.6 : uNoiseStrength;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Modulate curl noise slightly over time"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 curlPos = pos * noiseFreq;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  curlPos.y += uTime * 0.15;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 turbulence = curlNoise(curlPos);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  force += turbulence * noiseStr;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Force C: Interactive mouse cursor reaction pushing particles"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 toMouse = pos - uMousePos;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float distToMouse = length(toMouse);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (distToMouse < uInteractionRadius && distToMouse > 0.001) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    float strengthFactor = (1.0 - (distToMouse / uInteractionRadius));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Soft easing curve"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    strengthFactor = strengthFactor * strengthFactor;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Push away from cursor"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    force += normalize(toMouse) * strengthFactor * uMouseStrength;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Constrain extreme speeds to prevent coordinates from expanding to infinity"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float maxSpeed = standout ? 18.0 : 12.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  float forceLen = length(force);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (forceLen > maxSpeed) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    force = (force / forceLen) * maxSpeed;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Position update equation: P_new = P_old + velocity * delta_t"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  vec3 nextPos = pos + force * uDeltaTime;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Store position and standout state tag in Alpha channel"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gl_FragColor = vec4(nextPos, standout ? 1.0 : 0.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "`;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
      }
    }
    overwrite: true
  }
}
