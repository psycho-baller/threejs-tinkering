        }
        lines {
          text: "      lElbow = createJoint(-0.28, 0.75, 0.1);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      lWrist = createJoint(-0.2, 0.45, 0.2);"
